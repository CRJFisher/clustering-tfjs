{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "module": "ES2020",
    "outDir": "dist",
    "declaration": false,
    "rootDir": "src"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "test_support",
    "__fixtures__"
  ]
}
